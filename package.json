{
  "name": "@sheetodm/core",
  "version": "0.0.1",
  "description": "ODM para Google Sheets con NestJS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "test": "jest",
    "start:dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/main.ts"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.26",
    "@swc/core": "^1.15.41",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/testing": "^11.1.26",
    "axios": "^1.17.0",
    "googleapis": "^173.0.0",
    "nanoid": "^5.1.11",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^14.0.0"
  }
}
